# =============================================================================
# Local Hardware Configuration - copy to .env and fill in your values
# =============================================================================

# [Audio - actions/audio_utils/transcribe_audio.py]
AUDIO_UTILS_HF_TOKEN=your_hugging_face_token_here

# Number of CPU threads for OpenMP (torch/whisper inference)
OMP_NUM_THREADS=8

# [Picture - actions/picture_utils/thumbnailing.py]
# Max concurrent NVENC GPU encoding sessions (consumer cards: typically 3-5)
THUMBNAIL_MAX_GPU_SESSIONS=3

# Number of CPU cores for parallel thumbnail processing
THUMBNAIL_NUM_CORES=4

# [Picture - actions/picture_utils/raw_to_jpg/raw2jpeg.py]
# Number of CPU cores for parallel RAW -> JPEG conversion
RAW_TO_JPG_NUM_CORES=4

# [AI - actions/ai_utils/]
# Engine: 'lmstudio' or 'ollama'  (can be overridden per-run with --engine)
AI_ENGINE=lmstudio

# --- LMStudio (OpenAI-compatible API, typically on Windows host) ----------
LM_STUDIO_HOST=http://localhost:1234

# Map-Reduce-Refine — Phase 1/2: high-reasoning model, small context
LM_STUDIO_MODEL_A=your_map_model_id_here
LM_STUDIO_MODEL_A_CTX=4096
# Map-Reduce-Refine — Phase 3: large-context model (refine/coherence)
LM_STUDIO_MODEL_B=your_refine_model_id_here
LM_STUDIO_MODEL_B_CTX=52500
# Single-model fallback (both phases use this if MODEL_A/MODEL_B not set)
LM_STUDIO_MODEL=your_model_id_here

# --- Ollama (runs natively on Linux/WSL2, default port 11434) -------------
OLLAMA_HOST=http://localhost:11434

# Map-Reduce-Refine — Phase 1/2 model (name:tag format, e.g. gemma3:12b)
OLLAMA_MODEL_A=your_map_model_name:tag
OLLAMA_MODEL_A_CTX=4096
# Map-Reduce-Refine — Phase 3 model (e.g. gemma3:27b)
OLLAMA_MODEL_B=your_refine_model_name:tag
OLLAMA_MODEL_B_CTX=8192
# Single-model fallback for Ollama
OLLAMA_MODEL=your_model_name:tag

# [NAS]
NAS_HOST=nas.home.arpa
NAS_USER=your_nas_user
NAS_PASS=your_nas_password
NAS_SHARES=homes,home,programmes,video,backups,server
